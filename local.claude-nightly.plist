<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>local.claude-nightly</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/eduardkakosyan/claude-autonomous/scripts/claude-nightly.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/eduardkakosyan/claude-autonomous/workspace</string>

    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>2</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
        <key>HOME</key>
        <string>/Users/eduardkakosyan</string>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/eduardkakosyan/claude-autonomous/logs/launchd-stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/eduardkakosyan/claude-autonomous/logs/launchd-stderr.log</string>

    <key>Nice</key>
    <integer>5</integer>
</dict>
</plist>
